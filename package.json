{
  "name": "summitjs",
  "version": "0.4.2",
  "description": "The open source, AI Agent Native JavaScript framework. Add reactive behavior directly in your HTML with signal-powered s- directives and $ magics. No build step, CSP-safe, about 16KB.",
  "type": "module",
  "license": "MIT",
  "author": "anishfyi (https://github.com/anishfyi)",
  "homepage": "https://velofy.github.io/summitjs/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velofy/summitjs.git"
  },
  "bugs": {
    "url": "https://github.com/velofy/summitjs/issues"
  },
  "keywords": [
    "summit",
    "summitjs",
    "signals",
    "reactivity",
    "html",
    "directives",
    "alpine",
    "frontend",
    "framework",
    "ai-agent",
    "progressive-enhancement",
    "csp-safe"
  ],
  "main": "./dist/summit.cjs",
  "module": "./dist/summit.js",
  "types": "./dist/summit.d.ts",
  "unpkg": "./dist/summit.min.js",
  "jsdelivr": "./dist/summit.min.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/summit.d.ts",
        "default": "./dist/summit.js"
      },
      "require": {
        "types": "./dist/summit.d.cts",
        "default": "./dist/summit.cjs"
      }
    },
    "./net": {
      "import": {
        "types": "./dist/net.d.ts",
        "default": "./dist/net.js"
      },
      "require": {
        "types": "./dist/net.d.cts",
        "default": "./dist/net.cjs"
      }
    },
    "./cdn": "./dist/summit.min.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "AGENTS.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && node scripts/rename-cdn.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "size": "node scripts/size.mjs",
    "smoke": "node scripts/smoke.mjs",
    "verify": "node scripts/verify-page.mjs",
    "docs": "node scripts/build-docs.mjs",
    "verify:docs": "node scripts/verify-docs.mjs",
    "check": "npm run typecheck && npm test && npm run build && npm run size && npm run smoke && npm run verify && npm run docs && npm run verify:docs",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "prepack": "node scripts/readme-npm.mjs swap",
    "postpack": "node scripts/readme-npm.mjs restore"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "happy-dom": "^15.11.0",
    "marked": "^14.1.4",
    "prismjs": "^1.29.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
